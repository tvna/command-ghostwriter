# Vite emits content-hashed filenames under /assets/* -> safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The self-hosted Pyodide distribution lives at UNVERSIONED paths (/pyodide/pyodide.js,
# pyodide.asm.wasm, wheels), so it must NOT be immutable: a future Pyodide/wheel bump
# republishes different bytes at the same URL. Cache for a day, then revalidate so a
# returning user cannot run an outdated runtime against a new app bundle.
/pyodide/*
  Cache-Control: public, max-age=86400, must-revalidate

# The HTML entry must always revalidate so new deploys are picked up.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
